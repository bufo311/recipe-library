# PostgreSQL connection string from Supabase
# Supabase Dashboard → Settings → Database → Connection String → URI (Session mode, port 5432)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Supabase project URL
# Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://[ref].supabase.co

# Supabase service role key (keep this secret — never expose in the browser)
# Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Port for the Express server (default: 3000)
PORT=3000
