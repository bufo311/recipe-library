# Your Supabase project URL
# Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://[ref].supabase.co

# Your Supabase anon/public key (safe to expose in frontend code)
# Supabase Dashboard → Settings → API → anon public key
VITE_SUPABASE_ANON_KEY=eyJ...

# Base path for the app.
# If deploying to https://bufo311.github.io/recipe-library/ → keep as /recipe-library/
# If deploying to a custom domain at root → change to /
VITE_BASE_PATH=/recipe-library/
